# =============================
# Contrabajo Microservices (.gitignore)
# =============================

# Build outputs
/target/
/build/
/out/

# Logs
/logs/
*.log
*.log.*

# IDE / Editor
.idea/
*.iml
*.ipr
*.iws
.vscode/
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/
.apt_generated/

# OS
.DS_Store
Thumbs.db

# Temp / cache
*.tmp
*.temp
*.swp
*.swo
*~

# Java / Maven
*.class
.mvn/timing.properties

# Environment / secrets
.env
.env.*
!.env.example

# Spring local configs (no subir secretos locales)
application-local.yml
application-local.yaml
application-local.properties
application-dev-local.yml
application-dev-local.yaml
application-dev-local.properties

# Credential and key files
*.pem
*.p12
*.jks
*.keystore

# Test and runtime artifacts
*.h2.db
*.trace.db
